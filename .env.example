# Copy this file to ".env" and fill in your own values.
# All client-side env vars MUST be prefixed with VITE_ to be exposed to the app.

# EmailJS (https://dashboard.emailjs.com) — used by the contact form
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_TEMPLATE_ID_2=your_second_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Sanity CMS project id (https://www.sanity.io) — used to fetch projects/content
VITE_SANITY_PROJECT_ID=your_sanity_project_id
